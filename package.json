{
  "name": "nuxt-ai-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.0.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "deploy": "nuxt build && wrangler deploy",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "check": "npm run typecheck && npm run lint && npm run test",
    "check:publish": "node scripts/check-before-publish.mjs",
    "verify:portfolio": "npm run typecheck && npm run lint && npm run test:coverage && npm run build && npm run e2e -- --project=chromium --workers=1 && npm run check:publish",
    "capture:screenshots": "node scripts/capture-screenshots.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@nuxt/content": "^3.13.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/sitemap": "^8.0.13",
    "@tailwindcss/vite": "^4.2.4",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.0.0",
    "happy-dom": "^20.0.11",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7",
    "wrangler": "^4.84.1"
  }
}
